<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Mnemonic generation calls the user's own Gemini key; everything else is offline. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- allowBackup=false: the on-device API key and mistake history must never be swept
         into Auto Backup or device-to-device transfer (plan R23 / security review). -->
    <application
        android:name=".TarteelApp"
        android:allowBackup="false"
        android:label="Tarteel Companion"
        android:icon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.TarteelCompanion">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
